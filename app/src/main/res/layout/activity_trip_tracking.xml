<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy">

    <com.google.android.gms.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:paddingTop="20dp"
        android:layout_marginTop="26dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_dark_overlay"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/white"
            android:contentDescription="Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTripStatus"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="SEARCHING FOR DRIVER"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_pill_dark_overlay"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvHelp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help"
            android:textColor="@color/brand_blue"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <LinearLayout
        android:id="@+id/layoutDriverNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:layout_marginBottom="240dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnNavigate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Navigate"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:fontFamily="@font/poppins_bold"
            android:backgroundTint="@color/brand_blue"
            android:drawableStart="@drawable/ic_navigation"
            android:drawablePadding="6dp"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="24dp" />

        <Button
            android:id="@+id/btnOtherApp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Other App"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:backgroundTint="@color/surface_dark"
            android:drawableStart="@drawable/ic_open_in_new"
            android:drawablePadding="6dp"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- Bottom sheet -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet_dark"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="320dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="false">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_drag_handle" />

        <!-- Driver / Passenger card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imgDriverPhoto"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_circle_surface"
                android:src="@drawable/ic_user_avatar_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="Driver photo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finding driver..."
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:fontFamily="@font/poppins_semibold" />

                    <TextView
                        android:id="@+id/tvDriverRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="4.9 ★"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_rating_badge"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvVehicleInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gray_light"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>



        </LinearLayout>

        <TextView
            android:id="@+id/tvEtaBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="10dp"
            android:text="—"
            android:textColor="@color/brand_blue"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_pill_blue_outline" />


        <LinearLayout
            android:id="@+id/layoutContactButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnMessage"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="@color/surface_dark"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:icon="@drawable/ic_message"
                app:iconTint="@color/brand_blue"
                app:iconGravity="textStart"
                app:cornerRadius="22dp" />

            <Button
                android:id="@+id/btnCall"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:backgroundTint="@color/surface_dark"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:icon="@drawable/ic_phone"
                app:iconTint="@color/brand_blue"
                app:iconGravity="textStart"
                app:cornerRadius="22dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="16dp" />

        <!-- Journey section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Journey"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio_button_checked"
                app:tint="@color/brand_blue"
                android:contentDescription="Pickup" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvPickup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvPickupTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            android:background="@color/divider_color" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_location_pin"
                app:tint="@color/error_red"
                android:contentDescription="Dropoff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvDropoff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dropoff"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvDropoffTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

        </LinearLayout>

        <!-- Duration / Distance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURATION"
                        android:textColor="@color/gray_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.1" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_timer"
                            app:tint="@color/brand_blue"
                            android:contentDescription="Duration" />
                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="— min"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTANCE"
                        android:textColor="@color/gray_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.1" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_distance"
                            app:tint="@color/brand_blue"
                            android:contentDescription="Distance" />
                        <TextView
                            android:id="@+id/tvDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="— mi"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Fare breakdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_receipt"
                        app:tint="@color/brand_blue"
                        android:contentDescription="Fare" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Fare Breakdown"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutFareRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Paid"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:id="@+id/tvTotalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textColor="@color/brand_blue"
                            android:textSize="22sp"
                            android:fontFamily="@font/poppins_bold" />
                        <TextView
                            android:id="@+id/tvChargedTo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gray_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Passenger: Download + Book Similar -->
        <Button
            android:id="@+id/btnDownloadInvoice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:text="Download Invoice"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_bold"
            android:backgroundTint="@color/brand_blue"
            android:drawableStart="@drawable/ic_download"
            android:drawablePadding="8dp"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="28dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnBookSimilar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:text="Book Similar Ride"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:backgroundTint="@color/surface_dark"
            android:drawableStart="@drawable/ic_history"
            android:drawablePadding="8dp"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="28dp"
            android:visibility="gone" />

        <!-- Passenger: Cancel -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cancel Ride"
            android:textColor="@color/error_red"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            android:backgroundTint="@color/surface_dark"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="25dp"
            android:visibility="gone" />

        <!-- Driver: Slide to finish -->
        <FrameLayout
            android:id="@+id/layoutSlideToFinish"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_slide_track"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSlideLabel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Slide to finish trip →"
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold" />

            <ImageView
                android:id="@+id/ivSlideThumb"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_slide_thumb"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/dark_navy"
                android:contentDescription="Slide" />

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>