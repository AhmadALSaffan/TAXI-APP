<?xml version="1.0" encoding="utf-8"?>
<!-- activity_splash.xml — QuickRide Splash / Loading Screen -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy">


    <androidx.cardview.widget.CardView
        android:id="@+id/cardHero"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="60dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:id="@+id/imgHeroBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_city_night"
            android:contentDescription="City at night" />


        <ImageView
            android:id="@+id/imgCarIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_car_filled"
            app:tint="@color/brand_blue"
            android:contentDescription="QuickRide car icon" />

    </androidx.cardview.widget.CardView>


    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="TAXI APP"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:fontFamily="@font/poppins_bold"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cardHero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Premium city transit at your fingertips"
        android:textColor="@color/gray_light"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvInitializingLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INITIALIZING"
                android:textColor="@color/gray_light"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75%"
                android:textColor="@color/brand_blue"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>


        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progress="75"
            android:progressDrawable="@drawable/progress_bar_blue"
            android:max="100" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutSecure"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:id="@+id/icShield"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_shield_check"
            app:tint="@color/gray_muted"
            android:contentDescription="Secure" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="SECURE CONNECTION"
            android:textColor="@color/gray_muted"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>