<?xml version="1.0" encoding="utf-8"?>
<!-- activity_verify_phone.xml — QuickRide OTP Verification Screen -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy">


    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_circle_surface"
        android:src="@drawable/ic_arrow_left"
        app:tint="@color/white"
        android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <TextView
        android:id="@+id/tvScreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify Phone"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="@font/poppins_bold"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_circle_blue_alpha"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_smartphone_filled"
            app:tint="@color/brand_blue"
            android:contentDescription="Phone verification" />

    </FrameLayout>


    <TextView
        android:id="@+id/tvHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Enter Verification Code"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="@font/poppins_bold"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/iconContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="We\'ve sent a 6-digit verification code to"
        android:textColor="@color/gray_light"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="+1 (555) 000-1234"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_semibold"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvSubText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <LinearLayout
        android:id="@+id/layoutOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/tvPhoneNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <EditText
            android:id="@+id/etOtp1"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />


        <EditText
            android:id="@+id/etOtp2"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />


        <EditText
            android:id="@+id/etOtp3"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />


        <EditText
            android:id="@+id/etOtp4"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />


        <EditText
            android:id="@+id/etOtp5"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />


        <EditText
            android:id="@+id/etOtp6"
            android:layout_width="48dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_otp_box"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:cursorVisible="false" />

    </LinearLayout>


    <TextView
        android:id="@+id/tvResendLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Didn\'t receive the code?"
        android:textColor="@color/gray_muted"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular"
        app:layout_constraintTop_toBottomOf="@id/layoutOtp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Resend Code"
        android:textColor="@color/brand_blue"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_semibold"
        android:textStyle="bold"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvResendLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="12dp"
        android:indeterminateTint="@color/brand_blue"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnVerify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <Button
        android:id="@+id/btnVerify"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:text="Verify &amp; Continue"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_semibold"
        android:textStyle="bold"
        android:backgroundTint="@color/brand_blue"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@id/tvSecurePowered"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/tvSecurePowered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/gray_muted"
            android:contentDescription="Secure" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Secure verification powered by TaxiGo"
            android:textColor="@color/gray_muted"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>