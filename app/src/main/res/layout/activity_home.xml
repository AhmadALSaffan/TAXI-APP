<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy">

    <com.google.android.gms.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="46dp">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_dark_overlay"
            android:src="@drawable/ic_menu_hamburger"
            app:tint="@color/white"
            android:contentDescription="Menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvSystemActive"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="● SYSTEM ACTIVE"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_pill_dark_overlay"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/imgUserAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_user_avatar_placeholder"
            android:background="@drawable/bg_circle_surface"
            android:scaleType="centerCrop"
            android:contentDescription="User profile"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSearch"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="27dp"
            app:cardBackgroundColor="@color/surface_dark_semi"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/btnMenu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/search_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/brand_blue"
                    android:contentDescription="Search" />

                <EditText
                    android:id="@+id/etDestination"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:hint="Where to?"
                    android:textColorHint="@color/gray_muted"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"
                    android:background="@null"
                    android:inputType="none"
                    android:focusable="false"
                    android:imeOptions="actionSearch" />

                <ImageButton
                    android:id="@+id/btnSearchGo"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_circle_blue"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/white"
                    android:contentDescription="Search destination" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutMapControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/surface_dark_semi"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnZoomIn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/white"
                    android:contentDescription="Zoom in" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color" />

                <ImageButton
                    android:id="@+id/btnZoomOut"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:src="@drawable/ic_minus"
                    app:tint="@color/white"
                    android:contentDescription="Zoom out" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ImageButton
            android:id="@+id/btnMyLocation"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_circle_dark_overlay"
            android:src="@drawable/ic_my_location"
            app:tint="@color/white"
            android:contentDescription="My location" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet_dark"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="@dimen/bottom_sheet_peek_height"
        app:behavior_hideable="false">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_drag_handle"
            android:backgroundTint="@color/gray_muted" />

        <LinearLayout
            android:id="@+id/layoutShortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/btnShortcutHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_circle_surface">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_home"
                        app:tint="@color/brand_blue"
                        android:contentDescription="Home" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Home"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnShortcutWork"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_circle_surface">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_briefcase"
                        app:tint="@color/brand_blue"
                        android:contentDescription="Work" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Work"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnShortcutRecent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_circle_surface">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_history"
                        app:tint="@color/brand_blue"
                        android:contentDescription="Recent" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Recent"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnShortcutMore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_circle_surface">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_more_horizontal"
                        app:tint="@color/gray_light"
                        android:contentDescription="More" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="More"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRecommendedRide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_dark_blue"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_blue_dark">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lightning_bolt"
                        app:tint="@color/brand_blue"
                        android:contentDescription="Electric ride" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FutureLux X"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autonomous · 3 min away"
                        android:textColor="@color/gray_light"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$24.50"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOMMENDED"
                        android:textColor="@color/brand_blue"
                        android:textSize="9sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="0.05" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnConfirmDestination"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CONFIRM DESTINATION"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_bold"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:backgroundTint="@color/brand_blue"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="28dp" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/dark_navy"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="unlabeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
