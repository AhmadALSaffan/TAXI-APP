<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TAXIAPP" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.TAXIAPP" parent="Base.Theme.TAXIAPP" />

    <style name="roundedImage">
        <item name="cornerSize">15%</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="CountryPickerTheme"
        parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/CountryPickerSheet</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="CountryPickerSheet"
        parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@color/dark_navy</item>
        <item name="android:backgroundTint">@color/dark_navy</item>
    </style>
</resources>
